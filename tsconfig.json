{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client", "node"],
    
    /* Configuración para Alias @ */
    "paths": {
      "@src/*": ["./src/*"],
      "@app/*": ["./src/01-app/*"],
      "@pages/*": ["./src/02-pages/*"],
      "@widgets/*": ["./src/03-widgets/*"],
      "@features/*": ["./src/05-features/*"],
      "@features": ["./src/05-features/index.ts"],
      "@entities/*": ["./src/04-entities/*"],
      "@entities": ["./src/04-entities/index.ts"],
      "@shared/*": ["./src/06-shared/*"],
      "@hooks-ui/*": ["./src/06-shared/lib/hooks/*"],
      "@store-ui/*": ["./src/06-shared/store-ui/*"],
      "@ui-base/*": ["./src/06-shared/ui/base/*"],
      "@ui-modules/*": ["./src/06-shared/ui/modules/*"],
      "@context/*": ["./src/01-app/providers/*"],
      "@layouts/*": ["./src/01-app/layouts/*"],
      "@layouts": ["./src/01-app/layouts/index.ts"],
      "@config/*": ["./src/06-shared/config/*"],
      "@api/*": ["./src/06-shared/api/*"],
      "@api": ["./src/06-shared/api/index.ts"],
      "@assets/*": ["./src/06-shared/assets/*"],
      "@routes/*": ["./src/01-app/routes/*"],
      "@routes": ["./src/01-app/routes/index.ts"],
    }
  },
  "include": ["src"],
}
